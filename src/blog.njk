---
layout: base.njk
permalink: /blog/
---
{% block head %}
  <title>Blog - Maarten Tibau</title>
  {% include 'layouts/blocks/default-head-meta.njk' %}
{%  endblock %}

{% block content %}
<main class="row mb-xxl">
  {% for post in collections.posts | randomPost %}
  <div class="panel bg-grey-3 pt-lg pb-lg mb-xl">
    <div class="grid">
      <div class="col-24">
        <a  class="d-b" href="{{ post.url }}"  title="{{ post.data.title }}">
          <article class="article group-hover pt mt-md">
            <span class="article-label tt-u f-sm fw-medium rs pt-xxs pr pb-xxs pl lh-lg">Featured</span>
            <h3 class="mb-sm fw-extra-light f-xxl f-xl@sm group-c-primary">{{ post.data.title }}</h3>
            <div class="c-grey mb-xs f-sm@sm">{{ post.data.date | formatDate }}</div>
            <div class="c-secondary f-sm">{{ post.data.hashtags | formatHashtags }}</div>
          </article>
        </a>
      </div>
    </div>
  </div>
  {% endfor %}

  <ul class="articles elements-spacer-md">
    {% for post in collections.posts %}
      <li>
        <a href="{{ post.url }}" title="{{ post.data.title }}">
          <article class="article group-hover">
            <h3 class="mb-sm fw-extra-light f-xxl f-xl@sm group-c-primary">{{ post.data.title }}</h3>
            <div class="c-grey mb-xs f-sm@sm">{{ post.data.date | formatDate }}</div>
            <div class="c-secondary f-sm">{{ post.data.hashtags | formatHashtags }}</div>
          </article>
        </a>
      </li>
    {% endfor %}
  </ul>

  <ul class="pagination pt-lg">
    <li class="active"><a href="#0">1</a></li>
    <li><a href="#0">2</a></li>
    <li><a href="#0">3</a></li>
  </ul>
</main>
{%  endblock %}

{%  include 'layouts/components/get-in-touch.njk' %}
